---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const fmt = (d) => d.toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });

// Tag unici per i filtri, ordinati per frequenza
const tagCount = {};
for (const post of posts) {
  for (const t of post.data.tags ?? []) tagCount[t] = (tagCount[t] ?? 0) + 1;
}
const allTags = Object.keys(tagCount).sort((a, b) => tagCount[b] - tagCount[a]);
---
<Layout
  title="Blog — ITMatch"
  description="Articoli su AI recruiting, selezione di profili IT e automazione del lavoro del recruiter. Insight dal team ITMatch."
  lang="it"
>
  <Header lang="it" />

  <section class="blog-list">
    <div class="wrap">
      <span class="eyebrow">Blog</span>
      <h1>AI recruiting, raccontato da chi lo costruisce</h1>
      <p class="intro">Articoli e approfondimenti su come l'AI sta cambiando la selezione dei profili IT.</p>

      <div class="blog-layout">
        <!-- Colonna principale: articoli -->
        <div class="posts-col">
          <div class="posts" id="blog-posts">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class={`post-card ${post.data.heroImage ? 'has-img' : ''}`}
                data-id={post.id}
                data-title={post.data.title.toLowerCase()}
                data-desc={post.data.description.toLowerCase()}
                data-tags={(post.data.tags ?? []).join('|').toLowerCase()}
              >
                {post.data.heroImage && (
                  <div class="thumb">
                    <img src={post.data.heroImage} alt={post.data.heroAlt ?? ''} loading="lazy" />
                  </div>
                )}
                <div class="card-text">
                  <span class="date">{fmt(post.data.pubDate)}</span>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                  {(post.data.tags ?? []).length > 0 && (
                    <div class="card-tags">{(post.data.tags ?? []).map((t) => <span class="card-tag">{t}</span>)}</div>
                  )}
                  <span class="read">Leggi →</span>
                </div>
              </a>
            ))}
          </div>

          <p class="no-results" id="no-results" hidden>Nessun articolo trovato. Prova con un altro termine o tag.</p>
          {posts.length === 0 && <p class="empty">Nessun articolo pubblicato al momento.</p>}
        </div>

        <!-- Sidebar: ricerca, tag, indice -->
        <aside class="sidebar">
          <div class="sidebar-inner">
            <div class="search-box">
              <svg class="search-ic" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.6"/><path d="M14 14l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              <input type="search" id="blog-search" placeholder="Cerca…" autocomplete="off" aria-label="Cerca tra gli articoli" />
            </div>

            {allTags.length > 0 && (
              <div class="side-block">
                <span class="side-label">Argomenti</span>
                <div class="tag-filters" id="tag-filters">
                  <button class="tag-btn is-active" data-tag="">Tutti</button>
                  {allTags.map((tag) => <button class="tag-btn" data-tag={tag}>{tag}</button>)}
                </div>
              </div>
            )}

            <nav class="side-block index" id="blog-index" aria-label="Indice degli articoli">
              <span class="side-label">Indice</span>
              <ul>
                {posts.map((post) => (
                  <li data-index-for={post.id}>
                    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Footer lang="it" />
</Layout>

<script is:inline>
  (function () {
    const search = document.getElementById('blog-search');
    const tagFilters = document.getElementById('tag-filters');
    const cards = Array.from(document.querySelectorAll('#blog-posts .post-card'));
    const indexItems = Array.from(document.querySelectorAll('#blog-index [data-index-for]'));
    const noResults = document.getElementById('no-results');

    let query = '';
    let activeTag = '';

    function apply() {
      let visible = 0;
      const q = query.trim().toLowerCase();
      cards.forEach((card) => {
        const title = card.dataset.title || '';
        const desc = card.dataset.desc || '';
        const tags = card.dataset.tags || '';
        const matchesText = !q || title.includes(q) || desc.includes(q) || tags.includes(q);
        const matchesTag = !activeTag || tags.split('|').includes(activeTag);
        const show = matchesText && matchesTag;
        card.style.display = show ? '' : 'none';
        const idxItem = indexItems.find((li) => li.dataset.indexFor === card.dataset.id);
        if (idxItem) idxItem.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.hidden = visible !== 0;
    }

    if (search) search.addEventListener('input', (e) => { query = e.target.value; apply(); });

    if (tagFilters) {
      tagFilters.addEventListener('click', (e) => {
        const btn = e.target.closest('.tag-btn');
        if (!btn) return;
        activeTag = (btn.dataset.tag || '').toLowerCase();
        tagFilters.querySelectorAll('.tag-btn').forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        apply();
      });
    }
  })();
</script>

<style>
  .blog-list { padding: 70px 0 90px; }
  .blog-list .wrap { max-width: 1080px; }
  .eyebrow { font-family: var(--font-sans); font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); font-weight: 600; }
  .blog-list h1 { font-size: 42px; line-height: 1.12; color: var(--ink); margin: 12px 0 14px; letter-spacing: -0.02em; }
  .intro { font-size: 18px; color: var(--muted); margin: 0 0 40px; line-height: 1.6; }

  /* ---- layout a due colonne ---- */
  .blog-layout { display: grid; grid-template-columns: 1fr 280px; gap: 44px; align-items: start; }
  .posts-col { min-width: 0; }

  /* ---- sidebar ---- */
  .sidebar-inner { position: sticky; top: 90px; display: flex; flex-direction: column; gap: 26px; }
  .side-block { }
  .side-label { display: block; font-family: var(--font-sans); font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--muted-2); font-weight: 600; margin-bottom: 12px; }

  .search-box { position: relative; }
  .search-ic { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); width: 17px; height: 17px; color: var(--muted-2); pointer-events: none; }
  #blog-search { width: 100%; box-sizing: border-box; padding: 12px 16px 12px 40px; font-size: 15px; font-family: var(--font-sans); color: var(--ink); border: 1px solid var(--line); border-radius: 10px; background: #fff; transition: border-color .15s ease, box-shadow .15s ease; }
  #blog-search:focus { outline: none; border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-50); }

  .tag-filters { display: flex; flex-wrap: wrap; gap: 7px; }
  .tag-btn { font-family: var(--font-sans); font-size: 12.5px; color: var(--muted); background: #fff; border: 1px solid var(--line); padding: 6px 12px; border-radius: 999px; cursor: pointer; transition: all .15s ease; }
  .tag-btn:hover { border-color: var(--brand-200, #c7d2fe); color: var(--ink); }
  .tag-btn.is-active { background: var(--brand); border-color: var(--brand); color: #fff; }

  .index ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 10px; }
  .index li { font-size: 14px; line-height: 1.4; }
  .index a { color: var(--ink-2, #2c3440); text-decoration: none; border-bottom: 1px solid transparent; transition: color .12s ease, border-color .12s ease; }
  .index a:hover { color: var(--brand); border-bottom-color: var(--brand-300); }

  /* ---- card articoli ---- */
  .posts { display: flex; flex-direction: column; gap: 14px; }
  .post-card { display: block; padding: 28px 30px; border: 0.5px solid var(--line); border-radius: var(--radius-lg, 16px); text-decoration: none; transition: border-color .15s ease, box-shadow .15s ease, transform .15s ease; background: #fff; }
  .post-card.has-img { display: grid; grid-template-columns: 200px 1fr; gap: 24px; align-items: center; padding: 18px; }
  .post-card:hover { border-color: var(--brand-200, #c7d2fe); box-shadow: 0 8px 30px -12px rgba(79,70,229,.18); transform: translateY(-2px); }
  .thumb { border-radius: 10px; overflow: hidden; border: 1px solid var(--line); aspect-ratio: 16 / 10; background: var(--paper-2); }
  .thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .post-card .date { font-size: 13px; color: var(--muted-2); }
  .post-card h2 { font-size: 21px; line-height: 1.25; color: var(--ink); margin: 8px 0 10px; letter-spacing: -0.01em; }
  .post-card p { font-size: 15px; color: var(--muted); line-height: 1.6; margin: 0 0 12px; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 6px; margin: 0 0 14px; }
  .card-tag { font-size: 11px; color: var(--brand); background: var(--brand-50); padding: 3px 9px; border-radius: 999px; }
  .post-card .read { font-size: 14px; color: var(--brand); font-weight: 600; }
  .no-results, .empty { color: var(--muted); font-size: 16px; padding: 20px 0; }

  /* ---- responsive: sidebar sopra, una colonna ---- */
  @media (max-width: 900px) {
    .blog-layout { grid-template-columns: 1fr; gap: 32px; }
    .sidebar { order: -1; }
    .sidebar-inner { position: static; flex-direction: column; gap: 20px; }
  }
  @media (max-width: 720px) {
    .blog-list h1 { font-size: 32px; }
    .post-card { padding: 22px; }
    .post-card.has-img { grid-template-columns: 1fr; gap: 16px; padding: 16px; }
  }
</style>
