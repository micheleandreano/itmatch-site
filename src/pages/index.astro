---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DemoForm from '../components/DemoForm.astro';
import Lightbox from '../components/Lightbox.astro';
import { Image } from 'astro:assets';

// Immagini prodotto ITMatch (7) — mappate ai blocchi del sito.
import heroCard from '../assets/itmatch/hero-scheda-candidato.png';
import aiLavora from '../assets/itmatch/ai-lavora-per-te.png';
import cvAnonimo from '../assets/itmatch/cv-anonimo.png';
import rilIntegra from '../assets/itmatch/ril-integrazione.png';
import risultatiMatch from '../assets/itmatch/risultati-matching.png';
import aiScreening from '../assets/itmatch/ai-screening-whatsapp.png';
import portaleClienti from '../assets/itmatch/portale-clienti-shortlist.png';
---
<Layout
  title="ITMatch — Trova candidati IT con l'AI. In pochi minuti."
  description="ITMatch automatizza ricerca, matching, screening e qualifica dei candidati IT grazie all'integrazione nativa con ReteInformaticaLavoro. Oltre 80.000 CV IT già integrati."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ITMatch",
      "applicationCategory": "BusinessApplication",
      "applicationSubCategory": "Recruiting / Applicant Tracking System",
      "operatingSystem": "Web",
      "description": "AI Recruiting Engine per il mercato IT: ricerca, matching, screening e qualifica automatizzati dei candidati IT. Oltre 80.000 CV IT integrati.",
      "url": "https://www.itmatch.app",
      "inLanguage": "it-IT",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "EUR", "description": "Richiedi una demo" },
      "publisher": {
        "@type": "Organization",
        "name": "Code&Career Srl",
        "url": "https://www.reteinformaticalavoro.it",
        "vatID": "IT14370520968",
        "address": { "@type": "PostalAddress", "streetAddress": "Via Adeodato Ressi 16", "addressLocality": "Milano", "addressCountry": "IT" }
      }
    })} />
  </Fragment>
  <Header lang="it" />

  <!-- ============ BLOCCO 1 · HERO ============ -->
  <section class="hero">
    <div class="wrap">
      <span class="reveal d1 hero-eyebrow">AI Recruiting Engine · verticale IT</span>
      <h1 class="reveal d1">Trova candidati IT<br>con l'AI. <em>In pochi minuti.</em></h1>
      <p class="reveal d2 lead">
        ITMatch automatizza ricerca, matching, screening e qualifica dei candidati IT
        grazie all'integrazione nativa con ReteInformaticaLavoro —
        <strong>oltre 80.000 CV IT già integrati.</strong>
      </p>
      <div class="reveal d3 cta-row">
        <a href="/demo/" class="btn btn-accent">Richiedi demo</a>
        <a href="#flow" class="btn-ghost">Guarda il matching AI</a>
      </div>
      <div class="reveal d4 trust-stats">
        <div class="stat"><b>80.000+</b><span>CV IT integrati</span></div>
        <div class="stat"><b>1.500</b><span>nuovi profili / mese</span></div>
        <div class="stat"><b>~70%</b><span>tempo operativo risparmiato</span></div>
      </div>
    </div>
    <div class="wrap hero-shot reveal d3" data-zoom>
      <Image src={heroCard} alt="ITMatch: scheda candidato con match AI all'88%, punti di forza e invio al cliente" widths={[600, 900, 1200, 1717]} sizes="(max-width: 980px) 100vw, 1080px" />
    </div>
  </section>

  <!-- ============ BLOCCO 2 · L'AI FA IL LAVORO OPERATIVO ============ -->
  <section id="prodotto" class="intro-prod">
    <div class="wrap">
      <span class="reveal d1 eyebrow">Il prodotto</span>
      <h2 class="reveal d1">L'AI fa il lavoro operativo.<br>Tu scegli le persone.</h2>
      <p class="reveal d2 sub">
        Compilazione dei profili, formatting delle job description, qualifica e screening,
        fino alla shortlist: ITMatch automatizza il lavoro ripetitivo del recruiter.
      </p>
    </div>
    <div class="wrap pano-img reveal d2" data-zoom data-zoom-src={aiLavora.src}>
      <Image src={aiLavora} alt="L'AI che lavora al posto tuo: estrae, compila, formatta, riduce errori e duplicazioni — fino al 70% di tempo risparmiato" widths={[700, 1100, 1536]} sizes="(max-width: 1000px) 100vw, 1280px" />
    </div>
  </section>

  <!-- sotto-feature: CV anonimo + clienti monitorati -->
  <section class="feat">
    <div class="wrap f-row reveal">
      <div class="f-text">
        <span class="eyebrow">CV anonimo</span>
        <h3>Il CV anonimo, professionale, in un click</h3>
        <p>ITMatch trasforma ogni profilo in una scheda pulita, completa e conforme al GDPR, pronta da inviare al cliente.</p>
        <ul class="checks">
          <li>Anonimizzazione totale di nome, contatti e dati sensibili</li>
          <li>Layout professionale e uniforme, con il tuo brand</li>
          <li>Competenze ed esperienze già messe in evidenza</li>
        </ul>
      </div>
      <div class="f-shot" data-zoom data-zoom-src={cvAnonimo.src}>
        <Image src={cvAnonimo} alt="CV anonimo e professionale generato da ITMatch" widths={[400,700,900,1536]} sizes="(max-width:860px) 100vw, 560px" />
      </div>
    </div>
  </section>

  <!-- ============ BLOCCO 3 · DATABASE IT GIÀ INTEGRATO ============ -->
  <section id="database" class="db">
    <div class="wrap db-head reveal d1">
      <span class="eyebrow on-dark">Database IT nativo</span>
      <h2>80.000+ CV IT. Già dentro ITMatch.</h2>
      <p>
        ITMatch nasce collegato a ReteInformaticaLavoro, il più grande database italiano
        di professionisti IT: profili reali, competenze strutturate, aggiornati ogni giorno —
        e interrogabili con la ricerca AI.
      </p>
    </div>
    <div class="wrap db-img reveal d2" data-zoom data-zoom-src={rilIntegra.src}>
      <Image src={rilIntegra} alt="ITMatch + ReteInformaticaLavoro: ricerca CV su oltre 80.000 profili IT con matching AI" widths={[700, 1100, 1536]} sizes="(max-width: 1000px) 100vw, 1280px" />
    </div>
  </section>

  <!-- ============ BLOCCO 4 · DAL JOB PROFILE ALLA SHORTLIST ============ -->
  <section id="flow" class="flow">
    <div class="wrap">
      <div class="flow-head reveal d1">
        <span class="eyebrow">Il flusso</span>
        <h2>Dal Job Profile alla shortlist</h2>
        <div class="flow-steps">
          <span>Job Profile</span><i>→</i><span>AI</span><i>→</i><span>Match</span><i>→</i><span>Screening</span><i>→</i><span>Cliente</span>
        </div>
      </div>

      <div class="flow-row reveal">
        <div class="flow-text">
          <h3>L'AI ti restituisce i match, già ordinati</h3>
          <p>Carichi il job profile con le skill richieste e l'AI ti restituisce i candidati compatibili, ciascuno con un punteggio e le competenze che combaciano già evidenziate.</p>
        </div>
        <div class="flow-shot" data-zoom data-zoom-src={risultatiMatch.src}>
          <Image src={risultatiMatch} alt="Risultati matching: candidati con score AI 88%, 82%, 74% e skill match" widths={[400,700,900,1536]} sizes="(max-width:860px) 100vw, 600px" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BLOCCO 5 · AI CANDIDATE SCREENING (WhatsApp) ============ -->
  <section id="screening" class="screening">
    <div class="wrap scr-grid">
      <div class="scr-text reveal d1">
        <span class="eyebrow on-dark">Feature killer</span>
        <h2>AI Candidate Screening,<br>su WhatsApp.</h2>
        <p>
          ITMatch contatta i candidati su WhatsApp, conduce la conversazione in modo naturale,
          raccoglie le informazioni che contano e ti restituisce un riepilogo strutturato —
          pronto per la qualifica.
        </p>
        <ul class="checks light">
          <li>Invio automatico con domande personalizzate sulla posizione</li>
          <li>Conversazione AI: disponibilità, RAL, modalità di lavoro</li>
          <li>Risposte sintetizzate e valutazione di compatibilità</li>
        </ul>
      </div>
      <div class="scr-shot reveal d2" data-zoom data-zoom-src={aiScreening.src}>
        <Image src={aiScreening} alt="ITMatch AI Screening: conversazione WhatsApp con il candidato e riepilogo risposte" widths={[400,700,900,1561]} sizes="(max-width:860px) 100vw, 620px" />
      </div>
    </div>
  </section>

  <!-- ============ BLOCCO 6 · PERCHÉ I RECRUITER IT USANO ITMATCH ============ -->
  <section id="perche" class="perche">
    <div class="wrap">
      <div class="perche-head reveal d1">
        <span class="eyebrow">I vantaggi</span>
        <h2>Perché i recruiter IT usano ITMatch</h2>
      </div>
      <div class="perche-grid">
        <div class="p-card reveal d1"><span class="p-ic">↓</span><h3>Meno sourcing manuale</h3><p>I candidati giusti emergono dal database, senza ore di ricerca booleana.</p></div>
        <div class="p-card reveal d1"><span class="p-ic">✕</span><h3>Meno CV inutili</h3><p>Solo profili con un match reale sulla posizione.</p></div>
        <div class="p-card reveal d2"><span class="p-ic">⎘</span><h3>Meno copia/incolla</h3><p>Compilazione, formatting e CV anonimo sono gestiti dall'AI.</p></div>
        <div class="p-card reveal d2"><span class="p-ic">⚡</span><h3>Più velocità</h3><p>Dal job profile alla shortlist in minuti, non in giorni.</p></div>
        <div class="p-card reveal d3"><span class="p-ic">✦</span><h3>Shortlist migliori</h3><p>Screening AI e punteggi di compatibilità su ogni candidato.</p></div>
        <div class="p-card reveal d3 accent"><span class="p-ic">→</span><h3>Tutto in un posto</h3><p>Sourcing, matching, screening e invio al cliente in un'unica piattaforma.</p></div>
      </div>
    </div>
  </section>

  <!-- ============ BLOCCO 7 · SCREENSHOT REALI ============ -->
  <section id="screenshot" class="shots">
    <div class="wrap">
      <div class="shots-head reveal d1">
        <span class="eyebrow">Dentro il prodotto</span>
        <h2>Schermate reali, non mockup</h2>
        <p>ITMatch è già in produzione. Il cliente riceve la shortlist in un portale dedicato, con match e feedback.</p>
      </div>
      <div class="shots-grid single">
        <figure class="shot wide reveal d1" data-zoom data-zoom-src={portaleClienti.src}>
          <Image src={portaleClienti} alt="Portale clienti ITMatch: shortlist con match e feedback del cliente" widths={[500,900,1300,1586]} sizes="(max-width:860px) 100vw, 900px" />
          <figcaption>Portale clienti · shortlist</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============ BLOCCO 8 · CTA FINALE + esperienza in coda ============ -->
  <section id="demo" class="cta">
    <div class="wrap cta-box reveal d1">
      <h2>Prova ITMatch su una posizione reale</h2>
      <p>Lasciaci i tuoi dati: ti mostriamo il matching AI sui tuoi profili, in una demo di 30 minuti.</p>
      <DemoForm lang="it" />
    </div>
    <p class="experience reveal d2">
      Costruito sull'esperienza di recruiting IT di
      <a href="https://reteinformaticalavoro.it" target="_blank" rel="noopener">ReteInformaticaLavoro</a>,
      piattaforma attiva nel settore IT da oltre 20 anni.
    </p>
  </section>

  <Lightbox />
  <Footer lang="it" />
</Layout>



<style>
  section { padding: 0; }
  .eyebrow { font-family: var(--font-sans); font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); font-weight: 600; }
  .eyebrow.on-dark { color: var(--brand-300); }

  /* ---------- HERO ---------- */
  .hero { padding: 76px 0 0; text-align: left; background: radial-gradient(120% 80% at 50% -10%, var(--brand-50) 0%, #fff 60%); }
  .hero-eyebrow { display:inline-block; font-size:12px; letter-spacing:.12em; text-transform:uppercase; color:var(--brand); font-weight:600; background:var(--brand-50); border:1px solid #dfe3fb; padding:7px 14px; border-radius:999px; margin-bottom:24px; }
  .hero h1 { font-size: 66px; line-height: 1.02; color: var(--ink); margin: 0 0 24px; max-width: 14ch; }
  .hero h1 em { font-style: normal; color: var(--brand); }
  .lead { font-size: 19px; line-height: 1.6; color: var(--muted); max-width: 60ch; margin: 0 0 32px; }
  .lead strong { color: var(--ink); font-weight: 600; }
  .cta-row { display: flex; gap: 22px; align-items: center; }
  .trust-stats { display:flex; gap:48px; margin-top:48px; padding-top:30px; border-top:.5px solid var(--line); }
  .stat { display:flex; flex-direction:column; }
  .stat b { font-family:var(--font-serif); font-size:30px; color:var(--ink); line-height:1; }
  .stat span { font-size:13px; color:var(--muted-2); margin-top:6px; }
  .hero-shot { margin-top: 54px; padding-bottom: 90px; }
  .hero-shot :global(img) { width: 100%; height: auto; border-radius: var(--radius-lg); border: 1px solid var(--line); box-shadow: 0 40px 80px -28px rgba(79,70,229,.32); }

  /* ---------- BLOCCO 2 intro + panorama ---------- */
  .intro-prod { padding: 104px 0 0; }
  .intro-prod h2 { font-size: 44px; line-height: 1.08; color: var(--ink); margin: 14px 0 18px; max-width: 20ch; }
  .intro-prod .sub { font-size: 18px; line-height: 1.6; color: var(--muted); max-width: 60ch; }
  .pano-img { margin-top: 44px; }
  .pano-img :global(img) { width: 100%; height: auto; border-radius: var(--radius-lg); border: 1px solid var(--line); box-shadow: 0 30px 70px -26px rgba(12,19,34,.22); }

  /* ---------- FEATURE rows ---------- */
  .feat { padding: 50px 0 90px; }
  .f-row { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; padding: 50px 0; }
  .f-row.reverse .f-text { order: 2; }
  .f-text h3 { font-size: 28px; line-height: 1.15; color: var(--ink); margin: 12px 0 14px; }
  .f-text p { font-size: 16px; line-height: 1.7; color: var(--muted); }
  .checks { list-style: none; padding: 0; margin: 22px 0 0; }
  .checks li { font-size: 15px; color: var(--ink-2); padding-left: 28px; position: relative; margin-bottom: 13px; }
  .checks li::before { content: "✓"; position: absolute; left: 0; color: var(--match); font-weight: 700; }
  .checks.light li { color: #d4dbe8; }
  .checks.light li::before { color: var(--match); }
  .f-shot { background: #fff; padding: 10px; border-radius: var(--radius); box-shadow: 0 24px 50px -22px rgba(12,19,34,.2); border: 1px solid var(--line); }
  .f-shot :global(img) { width: 100%; height: auto; border-radius: 6px; display: block; }

  /* ---------- BLOCCO 3 · DATABASE (dark) ---------- */
  .db { padding: 96px 0; background: linear-gradient(180deg, #0c1322 0%, #141d33 100%); text-align: center; }
  .db-head { max-width: 660px; margin: 0 auto 44px; }
  .db-head h2 { font-size: 42px; line-height: 1.08; color: #fff; margin: 14px 0 16px; }
  .db-head p { font-size: 17px; line-height: 1.65; color: #9fb0c4; margin: 0; }
  .db-img :global(img) { width: 100%; height: auto; border-radius: var(--radius-lg); border: 1px solid rgba(255,255,255,.1); box-shadow: 0 40px 90px -30px rgba(0,0,0,.6); }

  /* ---------- BLOCCO 4 · FLOW ---------- */
  .flow { padding: 100px 0; }
  .flow-head { text-align: center; max-width: 720px; margin: 0 auto 30px; }
  .flow-head h2 { font-size: 42px; line-height: 1.08; color: var(--ink); margin: 14px 0 26px; }
  .flow-steps { display:inline-flex; align-items:center; gap:12px; flex-wrap:wrap; justify-content:center; background:var(--paper-2); border:1px solid var(--line); border-radius:999px; padding:12px 22px; }
  .flow-steps span { font-family:var(--font-sans); font-size:14px; font-weight:600; color:var(--ink); }
  .flow-steps i { color:var(--brand); font-style:normal; font-weight:700; }
  .flow-row { display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center; padding:48px 0; }
  .flow-row.reverse .flow-text { order: 2; }
  .flow-text .num { font-family:var(--font-serif); font-size:15px; color:var(--brand); border:1.5px solid var(--brand); border-radius:50%; width:38px; height:38px; display:inline-flex; align-items:center; justify-content:center; margin-bottom:14px; }
  .flow-text h3 { font-size:27px; line-height:1.15; color:var(--ink); margin:0 0 12px; }
  .flow-text p { font-size:16px; line-height:1.7; color:var(--muted); }
  .flow-shot { background:#fff; padding:10px; border-radius:var(--radius); border:1px solid var(--line); box-shadow:0 24px 50px -22px rgba(12,19,34,.2); }
  .flow-shot :global(img) { width:100%; height:auto; border-radius:6px; display:block; }

  /* ---------- BLOCCO 5 · SCREENING (dark, accent) ---------- */
  .screening { padding: 96px 0; background: linear-gradient(135deg, var(--brand-700) 0%, #20184f 100%); }
  .scr-grid { display:grid; grid-template-columns: 1fr 1.05fr; gap: 60px; align-items:center; }
  .scr-text h2 { font-size: 42px; line-height: 1.06; color:#fff; margin: 14px 0 18px; }
  .scr-text p { font-size: 17px; line-height: 1.65; color: #cbd0f5; margin: 0; }
  .scr-shot { background: rgba(255,255,255,.04); padding: 10px; border-radius: var(--radius-lg); border: 1px solid rgba(255,255,255,.12); box-shadow: 0 40px 90px -30px rgba(0,0,0,.6); }
  .scr-shot :global(img) { width:100%; height:auto; border-radius:8px; display:block; }

  /* ---------- BLOCCO 6 · PERCHÉ ---------- */
  .perche { padding: 100px 0; }
  .perche-head { text-align:center; max-width:640px; margin:0 auto 44px; }
  .perche-head h2 { font-size:40px; line-height:1.08; color:var(--ink); margin:14px 0 0; }
  .perche-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  .p-card { background:#fff; border:1px solid var(--line); border-radius:var(--radius-lg); padding:28px 26px; transition:transform .18s ease, box-shadow .18s ease; }
  .p-card:hover { transform:translateY(-3px); box-shadow:0 18px 40px -18px rgba(12,19,34,.18); }
  .p-ic { display:inline-flex; align-items:center; justify-content:center; width:42px; height:42px; border-radius:11px; background:var(--brand-50); color:var(--brand); font-size:19px; font-weight:700; margin-bottom:16px; }
  .p-card h3 { font-size:19px; color:var(--ink); margin:0 0 8px; }
  .p-card p { font-size:14.5px; line-height:1.6; color:var(--muted); margin:0; }
  .p-card.accent { background:var(--brand); border-color:var(--brand); }
  .p-card.accent .p-ic { background:rgba(255,255,255,.18); color:#fff; }
  .p-card.accent h3 { color:#fff; }
  .p-card.accent p { color:#dfe1fb; }

  /* ---------- BLOCCO 7 · SCREENSHOT ---------- */
  .shots { padding: 96px 0; background: var(--paper-2); }
  .shots-head { text-align:center; max-width:640px; margin:0 auto 44px; }
  .shots-head h2 { font-size:40px; line-height:1.08; color:var(--ink); margin:14px 0 14px; }
  .shots-head p { font-size:17px; line-height:1.6; color:var(--muted); margin:0; }
  .shots-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
  .shots-grid.single { display:block; max-width:1000px; margin:0 auto; }
  .shot { margin:0; background:#fff; border:1px solid var(--line); border-radius:var(--radius); padding:10px; box-shadow:0 20px 44px -20px rgba(12,19,34,.16); }
  .shot.wide { grid-column:1 / -1; }
  .shot :global(img) { width:100%; height:auto; border-radius:6px; display:block; }
  .shot figcaption { font-size:13px; color:var(--muted-2); text-align:center; padding:12px 0 4px; letter-spacing:.02em; }

  /* ---------- BLOCCO 8 · CTA ---------- */
  .cta { padding: 104px 0; }
  .cta-box { background: linear-gradient(135deg, var(--ink) 0%, #1a2444 100%); border-radius: var(--radius-lg); padding: 60px 48px; text-align: center; max-width: 760px; margin: 0 auto; }
  .cta-box h2 { font-size: 38px; color: #fff; margin: 0 0 14px; }
  .cta-box p { color: #aab6c4; font-size: 17px; line-height: 1.6; margin: 0 auto 32px; max-width: 50ch; }
  .experience { text-align:center; font-size:14px; color:var(--muted-2); margin:36px auto 0; max-width:60ch; line-height:1.6; }
  .experience a { color:var(--brand); text-decoration:none; border-bottom:1px solid var(--brand-300); }
  .experience a:hover { color:var(--brand-700); }

  /* ---------- zoom hint (lightbox) ---------- */
  [data-zoom] { position: relative; }
  [data-zoom]::after {
    content: "⤢ Clicca per ingrandire";
    position: absolute; top: 16px; right: 16px;
    background: rgba(12,19,34,.82); color: #fff;
    font-family: var(--font-sans); font-size: 12px; font-weight: 500;
    padding: 7px 12px; border-radius: 8px;
    opacity: 0; transform: translateY(-4px); transition: opacity .2s ease, transform .2s ease;
    pointer-events: none; z-index: 2;
  }
  [data-zoom]:hover::after { opacity: 1; transform: translateY(0); }
  @media (max-width: 860px) { [data-zoom]::after { content: "⤢"; padding: 8px 10px; } }

  /* ---------- responsive ---------- */
  @media (max-width: 860px) {
    .hero { padding: 50px 0 0; }
    .hero h1 { font-size: 42px; }
    .lead { font-size: 17px; }
    .trust-stats { gap: 28px; flex-wrap: wrap; }
    .stat b { font-size: 24px; }
    .intro-prod h2, .db-head h2, .flow-head h2, .scr-text h2, .perche-head h2, .shots-head h2, .cta-box h2 { font-size: 30px; }
    .f-row, .f-row.reverse, .flow-row, .flow-row.reverse, .scr-grid { grid-template-columns: 1fr; gap: 32px; }
    .f-row.reverse .f-text, .flow-row.reverse .flow-text { order: 0; }
    .perche-grid { grid-template-columns: 1fr; }
    .shots-grid { grid-template-columns: 1fr; }
  }
</style>
