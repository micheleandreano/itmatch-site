---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import DemoForm from '../../components/DemoForm.astro';
---
<Layout
  lang="en"
  title="Request a demo — ITMatch"
  description="Request a free ITMatch demo: we'll show you the AI matching on your real IT profiles, in 30 minutes."
>
  <Header lang="en" />

  <section class="demo-page">
    <div class="wrap demo-grid">
      <div class="demo-left">
        <span class="eyebrow">Try ITMatch</span>
        <h1>Discover what<br>ITMatch can do for you.</h1>
        <p class="lead">
          Request a personalized (and free) demo tailored to your company's needs.
          Our team will show you the AI matching on your real profiles and the results you can achieve.
        </p>
        <ul class="demo-checks">
          <li>AI matching on a real position</li>
          <li>Automatic screening on WhatsApp</li>
          <li>Professional anonymous CV in one click</li>
          <li>Over 80,000 IT resumes already onboard</li>
        </ul>
        <p class="demo-exp">
          Built on the experience of
          <a href="https://reteinformaticalavoro.it" target="_blank" rel="noopener">ReteInformaticaLavoro</a>,
          active in IT recruiting for over 20 years.
        </p>
      </div>
      <div class="demo-right">
        <DemoForm lang="en" />
      </div>
    </div>
  </section>

  <Footer lang="en" />
</Layout>

<style>
  .demo-page { padding: 64px 0 90px; background: radial-gradient(120% 60% at 80% 0%, var(--brand-50) 0%, #fff 55%); }
  .demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .eyebrow { font-family: var(--font-sans); font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--brand); font-weight: 600; }
  .demo-left h1 { font-size: 46px; line-height: 1.08; color: var(--ink); margin: 14px 0 20px; letter-spacing: -0.02em; }
  .lead { font-size: 18px; line-height: 1.6; color: var(--muted); margin: 0 0 28px; }
  .demo-checks { list-style: none; padding: 0; margin: 0 0 30px; }
  .demo-checks li { position: relative; padding-left: 28px; margin-bottom: 12px; font-size: 16px; color: var(--ink); }
  .demo-checks li::before { content: "✓"; position: absolute; left: 0; color: var(--match); font-weight: 700; }
  .demo-exp { font-size: 14px; color: var(--muted-2); line-height: 1.6; }
  .demo-exp a { color: var(--brand); }
  .demo-right { background: var(--ink); border-radius: 20px; padding: 36px 34px; box-shadow: 0 30px 70px -30px rgba(12,19,34,.4); }
  @media (max-width: 900px) {
    .demo-grid { grid-template-columns: 1fr; gap: 40px; }
    .demo-left h1 { font-size: 36px; }
    .demo-right { padding: 28px 22px; }
  }
</style>
