---
// Header ITMatch — bilingue (IT default / EN su /en/).
import { Image } from 'astro:assets';
import logo from '../assets/itmatch/logo-itmatch.png';

interface Props { lang?: 'it' | 'en'; }
const { lang = 'it' } = Astro.props;
const base = lang === 'en' ? '/en/' : '/';

const t = {
  it: { prodotto: 'Prodotto', database: 'Database IT', screening: 'AI Screening', perche: 'Perché ITMatch', cta: 'Richiedi demo' },
  en: { prodotto: 'Product', database: 'IT Database', screening: 'AI Screening', perche: 'Why ITMatch', cta: 'Request a demo' },
}[lang];

// URL gemello per il selettore lingua
const path = Astro.url.pathname;
const itUrl = path.replace(/^\/en\//, '/').replace(/^\/en$/, '/');
const enUrl = path.startsWith('/en') ? path : ('/en' + (path === '/' ? '/' : path));
---
<header class="hdr">
  <div class="wrap row">
    <a href={base} class="logo" aria-label="ITMatch home">
      <Image src={logo} alt="ITMatch" widths={[180, 280, 360]} sizes="180px" />
    </a>
    <nav class="nav">
      <a href={`${base}#prodotto`}>{t.prodotto}</a>
      <a href={`${base}#database`}>{t.database}</a>
      <a href={`${base}#screening`} class="screening-link">
        <svg class="wa-ic" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2zm0 18.15h-.01c-1.52 0-3.01-.41-4.3-1.18l-.31-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.35c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.69 8.23-8.23 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29z" fill="currentColor"/></svg>
        {t.screening}
      </a>
      <a href={`${base}#perche`}>{t.perche}</a>
      <span class="lang">
        <a href={itUrl} class={lang === 'it' ? 'on' : ''}>IT</a>
        <span class="sep">/</span>
        <a href={enUrl} class={lang === 'en' ? 'on' : ''}>EN</a>
      </span>
      <a href={lang === "en" ? "/en/demo/" : "/demo/"} class="btn btn-dark nav-cta">{t.cta}</a>
    </nav>
  </div>
</header>

<style>
  .hdr { position: sticky; top: 0; z-index: 50; background: rgba(255,255,255,.92); backdrop-filter: blur(10px); border-bottom: 0.5px solid var(--line); }
  .row { display: flex; align-items: center; justify-content: space-between; height: 76px; }
  .logo { display: flex; align-items: center; text-decoration: none; }
  .logo :global(img) { height: 38px; width: auto; display: block; }
  .nav { display: flex; align-items: center; gap: 28px; }
  .nav > a { font-size: 14px; color: var(--muted); text-decoration: none; }
  .nav > a:hover { color: var(--ink); }
  .screening-link { display: inline-flex; align-items: center; gap: 6px; }
  .wa-ic { width: 17px; height: 17px; color: #25D366; flex-shrink: 0; }
  .nav-cta { color: #fff !important; padding: 10px 18px; font-size: 14px; }
  .lang { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; }
  .lang a { color: var(--muted-2); text-decoration: none; font-weight: 600; }
  .lang a.on { color: var(--brand); }
  .lang a:hover { color: var(--ink); }
  .lang .sep { color: var(--line); }
  @media (max-width: 820px) { .nav > a:not(.nav-cta) { display: none; } .lang { display: none; } .logo :global(img) { height: 34px; } }
</style>
